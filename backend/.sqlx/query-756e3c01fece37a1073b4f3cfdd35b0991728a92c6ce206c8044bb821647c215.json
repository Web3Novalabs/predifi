{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            p.pool_id,\n            pl.name   AS pool_name,\n            pl.result AS pool_result,\n            p.outcome,\n            p.amount,\n            p.created_at\n        FROM predictions p\n        JOIN pools pl ON pl.pool_id = p.pool_id\n        WHERE p.user_address = $1\n        ORDER BY p.created_at DESC\n        LIMIT $2 OFFSET $3\n        ",
