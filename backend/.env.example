# Server
PREDIFI_APP_HOST=0.0.0.0
PREDIFI_APP_PORT=3000
RUST_LOG=info

# CORS — comma-separated list of allowed origins.
# Each entry must be a valid http:// or https:// origin (scheme + host + optional port).
# Paths, query strings, fragments, wildcards, and the 'null' origin are not permitted.
# Defaults to: http://localhost:3000,http://localhost:5173,https://predifi.app
# PREDIFI_CORS_ALLOWED_ORIGINS=https://predifi.app,https://admin.predifi.app

# PostgreSQL
PREDIFI_DATABASE_URL=postgres://postgres:postgres@localhost:5432/predifi
PREDIFI_DB_MAX_CONNECTIONS=10
PREDIFI_DB_MIN_CONNECTIONS=1
PREDIFI_DB_ACQUIRE_TIMEOUT_SECS=30

# Redis (for caching hot data - issue #714)
PREDIFI_REDIS_URL=redis://localhost:6379

# Stellar RPC
PREDIFI_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
PREDIFI_RPC_HEALTH_TIMEOUT_SECS=2
PREDIFI_RPC_HEALTH_RETRY_COUNT=3
# Timeout for general Stellar RPC calls (event listener, sync worker)
PREDIFI_RPC_TIMEOUT_SECS=10

# Fee Configuration
PREDIFI_TREASURY_FEE_BPS=300
PREDIFI_REFERRAL_FEE_BPS=5000

# Sentry (optional — leave unset to disable error reporting)
# PREDIFI_SENTRY_DSN=https://your-key@sentry.io/your-project
